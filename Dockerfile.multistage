# Stage 1 - Build

FROM maven:3.9.9-eclipse-temurin-21 AS builder

WORKDIR /app

COPY app/build-optimization-demo .

RUN mvn clean package


# Stage 2 - Runtime

FROM eclipse-temurin:21-jre

WORKDIR /app

COPY --from=builder \
/app/target/build-optimization-demo-1.0-SNAPSHOT.jar \
app.jar

CMD ["java","-jar","app.jar"]